# PostgreSQL接続文字列 (RenderのInternal Database URLをコピー)
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# NextAuth用のシークレット (openssl rand -base64 32 で生成)
NEXTAUTH_SECRET="your-super-secret-key-change-this"
NEXTAUTH_URL="http://localhost:3000"

# Socket.IOサーバーのポート
SOCKET_PORT=3001
NEXT_PUBLIC_SOCKET_URL="http://localhost:3001"

# 管理者初期パスワード (初回起動時のadminアカウント用)
ADMIN_INITIAL_PASSWORD="admin1234"

# ImageKit (画像アップロード用。imagekit.io のダッシュボードから取得)
# 注意: IMAGEKIT_PRIVATE_KEY は絶対に公開リポジトリにコミットしないこと
IMAGEKIT_PUBLIC_KEY="your_public_key"
IMAGEKIT_PRIVATE_KEY="your_private_key"
IMAGEKIT_URL_ENDPOINT="https://ik.imagekit.io/your_imagekit_id"
